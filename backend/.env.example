# ========================
# REQUIRED - Set all these before deploying
# ========================

# MongoDB Atlas connection string (required - app will NOT start without this)
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/car_marketplace?retryWrites=true&w=majority

# JWT secret - use a long random string (min 32 chars)
JWT_SECRET=replace_with_a_very_long_random_secret_string_here
JWT_EXPIRE=30d

# Backend server port (Render sets this automatically)
PORT=5000

# Frontend origin for CORS (your Vercel URL in production, http://localhost:3000 in dev)
CLIENT_URL=http://localhost:3000

# ========================
# OPTIONAL - Cloudinary image uploads
# ========================
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
